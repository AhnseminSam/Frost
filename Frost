# Homepage
def simple_chatbot():
        print("Hello! I'm a simple chatbot. Please tell me your name.")
        userInputName = input("My name is: ")
        print(f"Nice to meet you, {userInputName}! Choose a mode: 'chat_mode' for chatting or 'math_mode' for solving math problems.")
