# This is the first mode: Math mode, it can calculate the expressions entered by the user. It only allows numbers and basic math operators and you can go to chat mode by typing 'exit'.
def math_mode():
    import math
    print("Welcome to math mode! You can enter a math expression, and I'll try to solve it for you.")
    while True:
        user_input = input("Enter a math expression (type 'exit' to leave math mode or 'chat_mode' to switch to chat mode): ")
        allowed_chars = "0123456789+-*/(). "
        if all(char in allowed_chars for char in user_input):
            try:
                result = eval(user_input)
                print(f"The answer is: {result}")
            except Exception as e:
                print(f"Error: {e}. Please enter a valid math expression.")
        elif user_input.lower() == 'exit':
            print("Exiting math mode. Returning to home.")
            simple_chatbot()
            break
        elif user_input.lower() == 'chat_mode':
            print("Switching to chat mode.")
            chat_mode()
            break
        else:
            print("Error: Invalid math expression!")

